#!/bin/sh
#
# MiniOS Session Manager GUI Launcher
# This script launches the graphical session manager application
#

set -e

case "${1:-}" in
    -h|--help)
        cat <<'EOF'
Usage: minios-session-manager

Launch the MiniOS Session Manager graphical interface.

This command opens the GTK application for browsing, creating, activating,
resizing, deleting, exporting, importing, copying, and converting sessions.

For the command-line interface, run: minios-session --help
For the manual page, run: man minios-session-manager
EOF
        exit 0
        ;;
esac

# Find the real directory of the script
SCRIPT_DIR=$(dirname "$(readlink -f -- "$0")")

# Check for installed location first
if [ -f "/usr/lib/minios-session-manager/minios_session_manager.py" ]; then
    DIR="/usr/lib/minios-session-manager"
else
    # Assume running from source, construct path relative to this script
    DIR="$(dirname "$SCRIPT_DIR")/lib"
fi

exec python3 -u "$DIR/minios_session_manager.py" "$@"
