#: debian/minios-session-manager/usr/lib/minios-session-manager/minios_session.py:2503
#: lib/minios_session.py:2503
msgid "MiniOS Session Manager - Command line tool for managing persistent sessions"
msgstr "MiniOS Session Manager - Herramienta de línea de comandos para gestionar sesiones persistentes"

#: debian/minios-session-manager/usr/lib/minios-session-manager/minios_session.py:2505
#: lib/minios_session.py:2505
msgid ""
"\n"
"GLOBAL OPTIONS:\n"
"  --json                    Output results in JSON format (can be used with any command)\n"
"  --sessions-dir PATH       Use custom sessions directory instead of default\n"
"\n"
"COMMANDS:\n"
"  list                      List all available sessions with detailed information\n"
"  active                    Show currently active session (will boot next)\n"
"  running                   Show currently running session (current boot)\n"
"  info                      Show filesystem type and compatible session modes\n"
"  activate SESSION_ID       Activate specified session\n"
"  create [MODE] [SIZE]      Create new session using positional arguments\n"
"  delete SESSION_ID         Delete specified session\n"
"  cleanup [--days N]        Delete old sessions (default: 30 days)\n"
"  status                    Check sessions directory status and permissions\n"
"  resize SESSION_ID SIZE    Resize session to new size in MB (dynfilefs/raw only)\n"
"  export SESSION_ID PATH    Export session to .tar.zst archive\n"
"  import ARCHIVE            Import session from .tar.zst archive\n"
"  copy SESSION_ID           Copy session (optional: --to-mode, --size)\n"
"  convert SESSION_ID MODE   Convert session to different mode (optional: --size)\n"
"\n"
"SESSION MODES:\n"
"  native                    Direct filesystem changes (requires POSIX-compatible filesystem)\n"
"  dynfilefs                 Dynamic file system overlay (works on any filesystem, 1000MB default)\n"
"  raw                       Raw disk image (works on any filesystem, custom size required)\n"
"\n"
"COMMAND BEHAVIOR:\n"
"  • create without MODE: Uses native mode (may fail on FAT32/NTFS/exFAT)\n"
"  • create without SIZE: Uses 1000MB for dynfilefs/raw modes\n"
"  • cleanup without --days: Uses 30-day threshold for deletion\n"
"  • cleanup protects both active and running sessions from deletion\n"
"\n"
"EXAMPLES:\n"
"\n"
"  Basic Usage:\n"
"    minios-session list                           List all available sessions\n"
"    minios-session active                         Show which session will boot next\n"
"    minios-session running                        Show currently running session\n"
"    minios-session info                           Show filesystem compatibility info\n"
"\n"
"  Session Management:\n"
"    minios-session activate 2                     Set session #2 as default for next boot\n"
"    minios-session delete 3                       Delete session #3 permanently\n"
"    minios-session cleanup --days 30              Delete sessions older than 30 days\n"
"    minios-session cleanup                        Delete sessions older than 30 days (default)\n"
"\n"
"  Creating Sessions:\n"
"    minios-session create                         Create native session (filesystem changes)\n"
"    minios-session create native                  Create native session explicitly\n"
"    minios-session create dynfilefs               Create 1000MB dynfilefs session (default size)\n"
"    minios-session create dynfilefs 8000          Create 8000MB dynfilefs session\n"
"    minios-session create raw 2000                Create 2000MB raw disk image\n"
"\n"
"  Session Operations:\n"
"    minios-session resize 2 4000                  Resize session #2 to 4000MB\n"
"    minios-session export 3 /tmp/backup.tar.zst   Export session #3 to archive\n"
"    minios-session import /tmp/backup.tar.zst     Import session from archive\n"
"    minios-session copy 2                         Copy session #2\n"
"    minios-session copy 2 --to-mode raw --size 3000  Copy session #2 as raw with 3000MB\n"
"    minios-session convert 3 dynfilefs --size 2000   Convert session #3 to dynfilefs with 2000MB\n"
"\n"
"  Error Handling:\n"
"    minios-session create                         May fail on FAT32/NTFS/exFAT: \"Use dynfilefs or raw mode\"\n"
"    minios-session create raw 5000                Will fail on FAT32: file size limit is 4096MB (4GB)\n"
"\n"
"  JSON Output (for automation):\n"
"    minios-session --json list                    List sessions in JSON format\n"
"    minios-session active --json                  Get active session info as JSON\n"
"    minios-session info --json                    Get system info as JSON\n"
"\n"
"  Custom Session Directory:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create native\n"
"\n"
"        "
msgstr ""
"\n"
"OPCIONES GLOBALES:\n"
"  --json                    Mostrar resultados en formato JSON (puede usarse con cualquier comando)\n"
"  --sessions-dir PATH       Usar un directorio de sesiones personalizado en lugar del predeterminado\n"
"\n"
"COMANDOS:\n"
"  list                      Listar todas las sesiones disponibles con información detallada\n"
"  active                    Mostrar la sesión actualmente activa (se iniciará en el próximo arranque)\n"
"  running                   Mostrar la sesión en ejecución actualmente (arranque actual)\n"
"  info                      Mostrar el tipo de sistema de archivos y modos de sesión compatibles\n"
"  activate SESSION_ID       Activar la sesión especificada\n"
"  create [MODE] [SIZE]      Crear una nueva sesión usando argumentos posicionales\n"
"  delete SESSION_ID         Eliminar la sesión especificada\n"
"  cleanup [--days N]        Eliminar sesiones antiguas (por defecto: 30 días)\n"
"  status                    Verificar el estado y permisos del directorio de sesiones\n"
"  resize SESSION_ID SIZE    Cambiar el tamaño de la sesión a un nuevo tamaño en MB (solo dynfilefs/raw)\n"
"  export SESSION_ID PATH    Exportar la sesión a un archivo .tar.zst\n"
"  import ARCHIVE            Importar una sesión desde un archivo .tar.zst\n"
"  copy SESSION_ID           Copiar una sesión (opcional: --to-mode, --size)\n"
"  convert SESSION_ID MODE   Convertir una sesión a un modo diferente (opcional: --size)\n"
"\n"
"MODOS DE SESIÓN:\n"
"  native                    Cambios directos en el sistema de archivos (requiere un sistema de archivos compatible con POSIX)\n"
"  dynfilefs                 Superposición de sistema de archivos dinámico (funciona en cualquier sistema de archivos, 1000MB por defecto)\n"
"  raw                       Imagen de disco sin procesar (funciona en cualquier sistema de archivos, se requiere tamaño personalizado)\n"
"\n"
"COMPORTAMIENTO DE LOS COMANDOS:\n"
"  • create sin MODE: Usa el modo native (puede fallar en FAT32/NTFS/exFAT)\n"
"  • create sin SIZE: Usa 1000MB para los modos dynfilefs/raw\n"
"  • cleanup sin --days: Usa un umbral de 30 días para la eliminación\n"
"  • cleanup protege tanto las sesiones activas como las en ejecución de ser eliminadas\n"
"\n"
"EJEMPLOS:\n"
"\n"
"  Uso Básico:\n"
"    minios-session list                           Listar todas las sesiones disponibles\n"
"    minios-session active                         Mostrar qué sesión se iniciará en el próximo arranque\n"
"    minios-session running                        Mostrar la sesión actualmente en ejecución\n"
"    minios-session info                           Mostrar información de compatibilidad del sistema de archivos\n"
"\n"
"  Gestión de Sesiones:\n"
"    minios-session activate 2                     Establecer la sesión #2 como predeterminada para el próximo arranque\n"
"    minios-session delete 3                       Eliminar permanentemente la sesión #3\n"
"    minios-session cleanup --days 30              Eliminar sesiones con más de 30 días\n"
"    minios-session cleanup                        Eliminar sesiones con más de 30 días (por defecto)\n"
"\n"
"  Creación de Sesiones:\n"
"    minios-session create                         Crear una sesión native (cambios en el sistema de archivos)\n"
"    minios-session create native                  Crear explícitamente una sesión native\n"
"    minios-session create dynfilefs               Crear una sesión dynfilefs de 1000MB (tamaño por defecto)\n"
"    minios-session create dynfilefs 8000          Crear una sesión dynfilefs de 8000MB\n"
"    minios-session create raw 2000                Crear una imagen de disco raw de 2000MB\n"
"\n"
"  Operaciones de Sesión:\n"
"    minios-session resize 2 4000                  Cambiar el tamaño de la sesión #2 a 4000MB\n"
"    minios-session export 3 /tmp/backup.tar.zst   Exportar la sesión #3 a un archivo\n"
"    minios-session import /tmp/backup.tar.zst     Importar una sesión desde un archivo\n"
"    minios-session copy 2                         Copiar la sesión #2\n"
"    minios-session copy 2 --to-mode raw --size 3000  Copiar la sesión #2 como raw con 3000MB\n"
"    minios-session convert 3 dynfilefs --size 2000   Convertir la sesión #3 a dynfilefs con 2000MB\n"
"\n"
"  Manejo de Errores:\n"
"    minios-session create                         Puede fallar en FAT32/NTFS/exFAT: \"Use dynfilefs o raw mode\"\n"
"    minios-session create raw 5000                Fallará en FAT32: el límite de tamaño de archivo es 4096MB (4GB)\n"
"\n"
"  Salida JSON (para automatización):\n"
"    minios-session --json list                    Listar sesiones en formato JSON\n"
"    minios-session active --json                  Obtener información de la sesión activa como JSON\n"
"    minios-session info --json                    Obtener información del sistema como JSON\n"
"\n"
"  Directorio de Sesiones Personalizado:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create native\n"
"\n"
"        "

