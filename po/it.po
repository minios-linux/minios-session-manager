#: lib/minios_session.py:952
msgid ""
"MiniOS Session Manager - Command line tool for managing persistent sessions"
msgstr ""
"MiniOS Session Manager - Strumento da riga di comando per la gestione delle "
"sessioni persistenti"

#: lib/minios_session.py:954
msgid ""
"\n"
"GLOBAL OPTIONS:\n"
"  --json                    Output results in JSON format (can be used with "
"any command)\n"
"  --sessions-dir PATH       Use custom sessions directory instead of "
"default\n"
"\n"
"COMMANDS:\n"
"  list                      List all available sessions with detailed "
"information\n"
"  active                    Show currently active session (will boot next)\n"
"  running                   Show currently running session (current boot)\n"
"  info                      Show filesystem type and compatible session "
"modes\n"
"  activate SESSION_ID       Activate specified session (required: "
"session_id)\n"
"  create [OPTIONS]          Create new session (optional: --mode, --size)\n"
"  delete SESSION_ID         Delete specified session (required: session_id)\n"
"  cleanup [OPTIONS]         Delete old sessions (optional: --days, default: "
"30)\n"
"\n"
"SESSION MODES:\n"
"  native                    Direct filesystem changes (requires POSIX-"
"compatible filesystem)\n"
"  dynfilefs                 Dynamic file system overlay (works on any "
"filesystem, 4GB default)\n"
"  raw                       Raw disk image (works on any filesystem, custom "
"size required)\n"
"\n"
"COMMAND BEHAVIOR:\n"
"  • create without --mode: Uses native mode (may fail on FAT32/NTFS)\n"
"  • create without --size: Uses 4000MB (4GB) for dynfilefs/raw modes\n"
"  • cleanup without --days: Uses 30-day threshold for deletion\n"
"  • cleanup protects both active and running sessions from deletion\n"
"\n"
"EXAMPLES:\n"
"\n"
"  Basic Usage:\n"
"    minios-session list                           List all available "
"sessions\n"
"    minios-session active                         Show which session will "
"boot next\n"
"    minios-session running                        Show currently running "
"session\n"
"    minios-session info                           Show filesystem "
"compatibility info\n"
"\n"
"  Session Management:\n"
"    minios-session activate 2                     Set session #2 as default "
"for next boot\n"
"    minios-session delete 3                       Delete session #3 "
"permanently\n"
"    minios-session cleanup --days 30              Delete sessions older than "
"30 days\n"
"    minios-session cleanup                        Delete sessions older than "
"30 days (default)\n"
"\n"
"  Creating Sessions:\n"
"    minios-session create --mode native           Create native session "
"(filesystem changes)\n"
"    minios-session create --mode dynfilefs        Create 4GB dynfilefs "
"session\n"
"    minios-session create --mode dynfilefs --size 8000   Create 8GB "
"dynfilefs session\n"
"    minios-session create --mode raw --size 2000         Create 2GB raw disk "
"image\n"
"\n"
"  Error Handling:\n"
"    minios-session create                         May fail on FAT32: \"Use "
"dynfilefs or raw mode\"\n"
"    minios-session create --mode raw --size 5000 May fail on FAT32: "
"\"Exceeds 4000MB limit\"\n"
"\n"
"  JSON Output (for automation):\n"
"    minios-session --json list                    List sessions in JSON "
"format\n"
"    minios-session active --json                  Get active session info as "
"JSON\n"
"    minios-session info --json                    Get system info as JSON\n"
"\n"
"  Custom Session Directory:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create --mode native\n"
"\n"
"NOTE: Most write operations (activate, create, delete, cleanup) require root "
"privileges.\n"
"      The tool will automatically request privileges when needed.\n"
"        "
msgstr ""
"\n"
"OPZIONI GLOBALI:\n"
"  --json                    Output i risultati in formato JSON (può essere "
"usato con qualsiasi comando)\n"
"  --sessions-dir PATH       Usa una directory personalizzata per le sessioni "
"invece di quella predefinita\n"
"\n"
"COMANDI:\n"
"  list                      Elenca tutte le sessioni disponibili con "
"informazioni dettagliate\n"
"  active                    Mostra la sessione attualmente attiva (che si "
"avvierà al prossimo boot)\n"
"  running                   Mostra la sessione attualmente in esecuzione ("
"boot corrente)\n"
"  info                      Mostra il tipo di filesystem e le modalità di "
"sessione compatibili\n"
"  activate SESSION_ID       Attiva la sessione specificata (richiesto: "
"session_id)\n"
"  create [OPZIONI]          Crea nuova sessione (opzionale: --mode, --size)\n"
"  delete SESSION_ID         Elimina la sessione specificata (richiesto: "
"session_id)\n"
"  cleanup [OPZIONI]         Elimina le vecchie sessioni (opzionale: --days, "
"predefinito: 30)\n"
"\n"
"MODALITÀ SESSIONE:\n"
"  native                    Modifiche dirette al filesystem (richiede "
"filesystem compatibile con POSIX)\n"
"  dynfilefs                 Overlay dinamico del filesystem (funziona su "
"qualsiasi filesystem, 4GB predefiniti)\n"
"  raw                       Immagine disco raw (funziona su qualsiasi "
"filesystem, dimensione personalizzata richiesta)\n"
"\n"
"COMPORTAMENTO DEI COMANDI:\n"
"  • create senza --mode: Usa la modalità nativa (potrebbe fallire su "
"FAT32/NTFS)\n"
"  • create senza --size: Usa 4000MB (4GB) per le modalità dynfilefs/raw\n"
"  • cleanup senza --days: Usa una soglia di 30 giorni per l'eliminazione\n"
"  • cleanup protegge le sessioni attive e in esecuzione dall'eliminazione\n"
"\n"
"ESEMPI:\n"
"\n"
"  Utilizzo Base:\n"
"    minios-session list                           Elenca tutte le sessioni "
"disponibili\n"
"    minios-session active                         Mostra quale sessione si "
"avvierà al prossimo boot\n"
"    minios-session running                        Mostra la sessione "
"attualmente in esecuzione\n"
"    minios-session info                           Mostra le informazioni di "
"compatibilità del filesystem\n"
"\n"
"  Gestione Sessioni:\n"
"    minios-session activate 2                     Imposta la sessione #2 come "
"predefinita per il prossimo boot\n"
"    minios-session delete 3                       Elimina la sessione #3 "
"permanentemente\n"
"    minios-session cleanup --days 30              Elimina le sessioni più "
"vecchie di 30 giorni\n"
"    minios-session cleanup                        Elimina le sessioni più "
"vecchie di 30 giorni (predefinito)\n"
"\n"
"  Creazione Sessioni:\n"
"    minios-session create --mode native           Crea una sessione nativa ("
"modifiche al filesystem)\n"
"    minios-session create --mode dynfilefs        Crea una sessione dynfilefs "
"da 4GB\n"
"    minios-session create --mode dynfilefs --size 8000   Crea una sessione "
"dynfilefs da 8GB\n"
"    minios-session create --mode raw --size 2000         Crea un'immagine "
"disco raw da 2GB\n"
"\n"
"  Gestione Errori:\n"
"    minios-session create                         Potrebbe fallire su FAT32: "
"\"Usa la modalità dynfilefs o raw\"\n"
"    minios-session create --mode raw --size 5000 Potrebbe fallire su FAT32: "
"\"Supera il limite di 4000MB\"\n"
"\n"
"  Output JSON (per automazione):\n"
"    minios-session --json list                    Elenca le sessioni in "
"formato JSON\n"
"    minios-session active --json                  Ottieni le informazioni "
"della sessione attiva come JSON\n"
"    minios-session info --json                    Ottieni le informazioni di "
"sistema come JSON\n"
"\n"
"  Directory Sessioni Personalizzata:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create --mode native\n"
"\n"
"NOTA: La maggior parte delle operazioni di scrittura (attivazione, creazione,"
" eliminazione, pulizia) richiedono privilegi di root.\n"
"      Lo strumento richiederà automaticamente i privilegi quando necessario.\n"
"        "

