#: debian/minios-session-manager/usr/lib/minios-session-manager/minios_session.py:2503
#: lib/minios_session.py:2503
msgid "MiniOS Session Manager - Command line tool for managing persistent sessions"
msgstr "MiniOS Session Manager - Strumento da riga di comando per la gestione delle sessioni persistenti"

#: debian/minios-session-manager/usr/lib/minios-session-manager/minios_session.py:2505
#: lib/minios_session.py:2505
msgid ""
"\n"
"GLOBAL OPTIONS:\n"
"  --json                    Output results in JSON format (can be used with any command)\n"
"  --sessions-dir PATH       Use custom sessions directory instead of default\n"
"\n"
"COMMANDS:\n"
"  list                      List all available sessions with detailed information\n"
"  active                    Show currently active session (will boot next)\n"
"  running                   Show currently running session (current boot)\n"
"  info                      Show filesystem type and compatible session modes\n"
"  activate SESSION_ID       Activate specified session\n"
"  create [MODE] [SIZE]      Create new session using positional arguments\n"
"  delete SESSION_ID         Delete specified session\n"
"  cleanup [--days N]        Delete old sessions (default: 30 days)\n"
"  status                    Check sessions directory status and permissions\n"
"  resize SESSION_ID SIZE    Resize session to new size in MB (dynfilefs/raw only)\n"
"  export SESSION_ID PATH    Export session to .tar.zst archive\n"
"  import ARCHIVE            Import session from .tar.zst archive\n"
"  copy SESSION_ID           Copy session (optional: --to-mode, --size)\n"
"  convert SESSION_ID MODE   Convert session to different mode (optional: --size)\n"
"\n"
"SESSION MODES:\n"
"  native                    Direct filesystem changes (requires POSIX-compatible filesystem)\n"
"  dynfilefs                 Dynamic file system overlay (works on any filesystem, 1000MB default)\n"
"  raw                       Raw disk image (works on any filesystem, custom size required)\n"
"\n"
"COMMAND BEHAVIOR:\n"
"  • create without MODE: Uses native mode (may fail on FAT32/NTFS/exFAT)\n"
"  • create without SIZE: Uses 1000MB for dynfilefs/raw modes\n"
"  • cleanup without --days: Uses 30-day threshold for deletion\n"
"  • cleanup protects both active and running sessions from deletion\n"
"\n"
"EXAMPLES:\n"
"\n"
"  Basic Usage:\n"
"    minios-session list                           List all available sessions\n"
"    minios-session active                         Show which session will boot next\n"
"    minios-session running                        Show currently running session\n"
"    minios-session info                           Show filesystem compatibility info\n"
"\n"
"  Session Management:\n"
"    minios-session activate 2                     Set session #2 as default for next boot\n"
"    minios-session delete 3                       Delete session #3 permanently\n"
"    minios-session cleanup --days 30              Delete sessions older than 30 days\n"
"    minios-session cleanup                        Delete sessions older than 30 days (default)\n"
"\n"
"  Creating Sessions:\n"
"    minios-session create                         Create native session (filesystem changes)\n"
"    minios-session create native                  Create native session explicitly\n"
"    minios-session create dynfilefs               Create 1000MB dynfilefs session (default size)\n"
"    minios-session create dynfilefs 8000          Create 8000MB dynfilefs session\n"
"    minios-session create raw 2000                Create 2000MB raw disk image\n"
"\n"
"  Session Operations:\n"
"    minios-session resize 2 4000                  Resize session #2 to 4000MB\n"
"    minios-session export 3 /tmp/backup.tar.zst   Export session #3 to archive\n"
"    minios-session import /tmp/backup.tar.zst     Import session from archive\n"
"    minios-session copy 2                         Copy session #2\n"
"    minios-session copy 2 --to-mode raw --size 3000  Copy session #2 as raw with 3000MB\n"
"    minios-session convert 3 dynfilefs --size 2000   Convert session #3 to dynfilefs with 2000MB\n"
"\n"
"  Error Handling:\n"
"    minios-session create                         May fail on FAT32/NTFS/exFAT: \"Use dynfilefs or raw mode\"\n"
"    minios-session create raw 5000                Will fail on FAT32: file size limit is 4096MB (4GB)\n"
"\n"
"  JSON Output (for automation):\n"
"    minios-session --json list                    List sessions in JSON format\n"
"    minios-session active --json                  Get active session info as JSON\n"
"    minios-session info --json                    Get system info as JSON\n"
"\n"
"  Custom Session Directory:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create native\n"
"\n"
"        "
msgstr ""
"\n"
"OPZIONI GLOBALI:\n"
"  --json                    Mostra i risultati in formato JSON (utilizzabile con qualsiasi comando)\n"
"  --sessions-dir PATH       Usa una directory personalizzata per le sessioni invece di quella predefinita\n"
"\n"
"COMANDI:\n"
"  list                      Elenca tutte le sessioni disponibili con informazioni dettagliate\n"
"  active                    Mostra la sessione attualmente attiva (che verrà avviata al prossimo boot)\n"
"  running                   Mostra la sessione attualmente in esecuzione (boot corrente)\n"
"  info                      Mostra il tipo di filesystem e le modalità di sessione compatibili\n"
"  activate SESSION_ID       Attiva la sessione specificata\n"
"  create [MODE] [SIZE]      Crea una nuova sessione utilizzando argomenti posizionali\n"
"  delete SESSION_ID         Elimina la sessione specificata\n"
"  cleanup [--days N]        Elimina le sessioni vecchie (predefinito: 30 giorni)\n"
"  status                    Controlla lo stato e i permessi della directory delle sessioni\n"
"  resize SESSION_ID SIZE    Ridimensiona la sessione alla nuova dimensione in MB (solo dynfilefs/raw)\n"
"  export SESSION_ID PATH    Esporta la sessione in un archivio .tar.zst\n"
"  import ARCHIVE            Importa una sessione da un archivio .tar.zst\n"
"  copy SESSION_ID           Copia la sessione (opzionale: --to-mode, --size)\n"
"  convert SESSION_ID MODE   Converte la sessione in una modalità diversa (opzionale: --size)\n"
"\n"
"MODALITÀ SESSIONE:\n"
"  native                    Modifiche dirette al filesystem (richiede un filesystem compatibile con POSIX)\n"
"  dynfilefs                 Overlay del filesystem dinamico (funziona su qualsiasi filesystem, 1000MB predefiniti)\n"
"  raw                       Immagine disco grezza (funziona su qualsiasi filesystem, dimensione personalizzata richiesta)\n"
"\n"
"COMPORTAMENTO DEI COMANDI:\n"
"  • create senza MODE: Usa la modalità native (potrebbe fallire su FAT32/NTFS/exFAT)\n"
"  • create senza SIZE: Usa 1000MB per le modalità dynfilefs/raw\n"
"  • cleanup senza --days: Usa una soglia di 30 giorni per l'eliminazione\n"
"  • cleanup protegge sia le sessioni attive che quelle in esecuzione dall'eliminazione\n"
"\n"
"ESEMPI:\n"
"\n"
"  Utilizzo Base:\n"
"    minios-session list                           Elenca tutte le sessioni disponibili\n"
"    minios-session active                         Mostra quale sessione verrà avviata al prossimo boot\n"
"    minios-session running                        Mostra la sessione attualmente in esecuzione\n"
"    minios-session info                           Mostra informazioni sulla compatibilità del filesystem\n"
"\n"
"  Gestione delle Sessioni:\n"
"    minios-session activate 2                     Imposta la sessione #2 come predefinita per il prossimo boot\n"
"    minios-session delete 3                       Elimina permanentemente la sessione #3\n"
"    minios-session cleanup --days 30              Elimina le sessioni più vecchie di 30 giorni\n"
"    minios-session cleanup                        Elimina le sessioni più vecchie di 30 giorni (predefinito)\n"
"\n"
"  Creazione di Sessioni:\n"
"    minios-session create                         Crea una sessione native (modifiche al filesystem)\n"
"    minios-session create native                  Crea esplicitamente una sessione native\n"
"    minios-session create dynfilefs               Crea una sessione dynfilefs di 1000MB (dimensione predefinita)\n"
"    minios-session create dynfilefs 8000          Crea una sessione dynfilefs di 8000MB\n"
"    minios-session create raw 2000                Crea un'immagine disco raw di 2000MB\n"
"\n"
"  Operazioni sulle Sessioni:\n"
"    minios-session resize 2 4000                  Ridimensiona la sessione #2 a 4000MB\n"
"    minios-session export 3 /tmp/backup.tar.zst   Esporta la sessione #3 in un archivio\n"
"    minios-session import /tmp/backup.tar.zst     Importa una sessione da un archivio\n"
"    minios-session copy 2                         Copia la sessione #2\n"
"    minios-session copy 2 --to-mode raw --size 3000  Copia la sessione #2 come raw con 3000MB\n"
"    minios-session convert 3 dynfilefs --size 2000   Converte la sessione #3 in dynfilefs con 2000MB\n"
"\n"
"  Gestione degli Errori:\n"
"    minios-session create                         Potrebbe fallire su FAT32/NTFS/exFAT: \"Usa modalità dynfilefs o raw\"\n"
"    minios-session create raw 5000                Fallirà su FAT32: limite dimensione file 4096MB (4GB)\n"
"\n"
"  Output JSON (per automazione):\n"
"    minios-session --json list                    Elenca le sessioni in formato JSON\n"
"    minios-session active --json                  Ottieni informazioni sulla sessione attiva in formato JSON\n"
"    minios-session info --json                    Ottieni informazioni di sistema in formato JSON\n"
"\n"
"  Directory Personalizzata per le Sessioni:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create native\n"
"\n"
"        "

