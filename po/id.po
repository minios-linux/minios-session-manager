#: lib/minios_session.py:2503
msgid ""
"MiniOS Session Manager - Command line tool for managing persistent sessions"
msgstr ""
"MiniOS Session Manager - Alat baris perintah untuk mengelola sesi persisten"

#: lib/minios_session.py:2505
msgid ""
"\n"
"GLOBAL OPTIONS:\n"
"  --json                    Output results in JSON format (can be used with "
"any command)\n"
"  --sessions-dir PATH       Use custom sessions directory instead of "
"default\n"
"\n"
"COMMANDS:\n"
"  list                      List all available sessions with detailed "
"information\n"
"  active                    Show currently active session (will boot next)\n"
"  running                   Show currently running session (current boot)\n"
"  info                      Show filesystem type and compatible session "
"modes\n"
"  activate SESSION_ID       Activate specified session\n"
"  create [MODE] [SIZE]      Create new session using positional arguments\n"
"  delete SESSION_ID         Delete specified session\n"
"  cleanup [--days N]        Delete old sessions (default: 30 days)\n"
"  status                    Check sessions directory status and permissions\n"
"  resize SESSION_ID SIZE    Resize session to new size in MB (dynfilefs/raw "
"only)\n"
"  export SESSION_ID PATH    Export session to .tar.zst archive\n"
"  import ARCHIVE            Import session from .tar.zst archive\n"
"  copy SESSION_ID           Copy session (optional: --to-mode, --size)\n"
"  convert SESSION_ID MODE   Convert session to different mode (optional: --"
"size)\n"
"\n"
"SESSION MODES:\n"
"  native                    Direct filesystem changes (requires POSIX-"
"compatible filesystem)\n"
"  dynfilefs                 Dynamic file system overlay (works on any "
"filesystem, 1000MB default)\n"
"  raw                       Raw disk image (works on any filesystem, custom "
"size required)\n"
"\n"
"COMMAND BEHAVIOR:\n"
"  • create without MODE: Uses native mode (may fail on FAT32/NTFS/exFAT)\n"
"  • create without SIZE: Uses 1000MB for dynfilefs/raw modes\n"
"  • cleanup without --days: Uses 30-day threshold for deletion\n"
"  • cleanup protects both active and running sessions from deletion\n"
"\n"
"EXAMPLES:\n"
"\n"
"  Basic Usage:\n"
"    minios-session list                           List all available "
"sessions\n"
"    minios-session active                         Show which session will "
"boot next\n"
"    minios-session running                        Show currently running "
"session\n"
"    minios-session info                           Show filesystem "
"compatibility info\n"
"\n"
"  Session Management:\n"
"    minios-session activate 2                     Set session #2 as default "
"for next boot\n"
"    minios-session delete 3                       Delete session #3 "
"permanently\n"
"    minios-session cleanup --days 30              Delete sessions older than "
"30 days\n"
"    minios-session cleanup                        Delete sessions older than "
"30 days (default)\n"
"\n"
"  Creating Sessions:\n"
"    minios-session create                         Create native session "
"(filesystem changes)\n"
"    minios-session create native                  Create native session "
"explicitly\n"
"    minios-session create dynfilefs               Create 1000MB dynfilefs "
"session (default size)\n"
"    minios-session create dynfilefs 8000          Create 8000MB dynfilefs "
"session\n"
"    minios-session create raw 2000                Create 2000MB raw disk "
"image\n"
"\n"
"  Session Operations:\n"
"    minios-session resize 2 4000                  Resize session #2 to "
"4000MB\n"
"    minios-session export 3 /tmp/backup.tar.zst   Export session #3 to "
"archive\n"
"    minios-session import /tmp/backup.tar.zst     Import session from "
"archive\n"
"    minios-session copy 2                         Copy session #2\n"
"    minios-session copy 2 --to-mode raw --size 3000  Copy session #2 as raw "
"with 3000MB\n"
"    minios-session convert 3 dynfilefs --size 2000   Convert session #3 to "
"dynfilefs with 2000MB\n"
"\n"
"  Error Handling:\n"
"    minios-session create                         May fail on FAT32/NTFS/"
"exFAT: \"Use dynfilefs or raw mode\"\n"
"    minios-session create raw 5000                Will fail on FAT32: file "
"size limit is 4096MB (4GB)\n"
"\n"
"  JSON Output (for automation):\n"
"    minios-session --json list                    List sessions in JSON "
"format\n"
"    minios-session active --json                  Get active session info as "
"JSON\n"
"    minios-session info --json                    Get system info as JSON\n"
"\n"
"  Custom Session Directory:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create native\n"
"\n"
"        "
msgstr ""
"\n"
"PILIHAN GLOBAL:\n"
"  --json                    Tampilkan hasil dalam format JSON (dapat "
"digunakan dengan perintah apa pun)\n"
"  --sessions-dir PATH       Gunakan direktori sesi kustom sebagai pengganti "
"default\n"
"\n"
"PERINTAH:\n"
"  list                      Daftar semua sesi yang tersedia dengan informasi "
"detail\n"
"  active                    Tampilkan sesi yang saat ini aktif (akan di-boot "
"berikutnya)\n"
"  running                   Tampilkan sesi yang sedang berjalan (boot saat "
"ini)\n"
"  info                      Tampilkan jenis filesystem dan mode sesi yang "
"kompatibel\n"
"  activate SESSION_ID       Aktifkan sesi yang ditentukan\n"
"  create [MODE] [SIZE]      Buat sesi baru menggunakan argumen posisi\n"
"  delete SESSION_ID         Hapus sesi yang ditentukan\n"
"  cleanup [--days N]        Hapus sesi lama (default: 30 hari)\n"
"  status                    Periksa status dan izin direktori sesi\n"
"  resize SESSION_ID SIZE    Ubah ukuran sesi ke ukuran baru dalam MB (hanya "
"dynfilefs/raw)\n"
"  export SESSION_ID PATH    Ekspor sesi ke arsip .tar.zst\n"
"  import ARCHIVE            Impor sesi dari arsip .tar.zst\n"
"  copy SESSION_ID           Salin sesi (opsional: --to-mode, --size)\n"
"  convert SESSION_ID MODE   Konversi sesi ke mode lain (opsional: --size)\n"
"\n"
"MODE SESI:\n"
"  native                    Perubahan langsung pada filesystem (memerlukan "
"filesystem yang kompatibel dengan POSIX)\n"
"  dynfilefs                 Overlay sistem file dinamis (berfungsi pada "
"filesystem apa pun, default 1000MB)\n"
"  raw                       Citra disk mentah (berfungsi pada filesystem apa "
"pun, ukuran kustom diperlukan)\n"
"\n"
"PERILAKU PERINTAH:\n"
"  • create tanpa MODE: Menggunakan mode native (mungkin gagal pada FAT32/"
"NTFS/exFAT)\n"
"  • create tanpa SIZE: Menggunakan 1000MB untuk mode dynfilefs/raw\n"
"  • cleanup tanpa --days: Menggunakan ambang batas 30 hari untuk "
"penghapusan\n"
"  • cleanup melindungi sesi aktif dan sesi yang sedang berjalan dari "
"penghapusan\n"
"\n"
"CONTOH:\n"
"\n"
"  Penggunaan Dasar:\n"
"    minios-session list                           Daftar semua sesi yang "
"tersedia\n"
"    minios-session active                         Tampilkan sesi yang akan "
"di-boot berikutnya\n"
"    minios-session running                        Tampilkan sesi yang sedang "
"berjalan\n"
"    minios-session info                           Tampilkan informasi "
"kompatibilitas filesystem\n"
"\n"
"  Manajemen Sesi:\n"
"    minios-session activate 2                     Tetapkan sesi #2 sebagai "
"default untuk boot berikutnya\n"
"    minios-session delete 3                       Hapus sesi #3 secara "
"permanen\n"
"    minios-session cleanup --days 30              Hapus sesi yang lebih lama "
"dari 30 hari\n"
"    minios-session cleanup                        Hapus sesi yang lebih lama "
"dari 30 hari (default)\n"
"\n"
"  Membuat Sesi:\n"
"    minios-session create                         Buat sesi native "
"(perubahan filesystem)\n"
"    minios-session create native                  Buat sesi native secara "
"eksplisit\n"
"    minios-session create dynfilefs               Buat sesi dynfilefs 1000MB "
"(ukuran default)\n"
"    minios-session create dynfilefs 8000          Buat sesi dynfilefs "
"8000MB\n"
"    minios-session create raw 2000                Buat citra disk mentah "
"2000MB\n"
"\n"
"  Operasi Sesi:\n"
"    minios-session resize 2 4000                  Ubah ukuran sesi #2 "
"menjadi 4000MB\n"
"    minios-session export 3 /tmp/backup.tar.zst   Ekspor sesi #3 ke arsip\n"
"    minios-session import /tmp/backup.tar.zst     Impor sesi dari arsip\n"
"    minios-session copy 2                         Salin sesi #2\n"
"    minios-session copy 2 --to-mode raw --size 3000  Salin sesi #2 sebagai "
"raw dengan 3000MB\n"
"    minios-session convert 3 dynfilefs --size 2000   Konversi sesi #3 ke "
"dynfilefs dengan 2000MB\n"
"\n"
"  Penanganan Kesalahan:\n"
"    minios-session create                         Mungkin gagal pada FAT32/"
"NTFS/exFAT: \"Gunakan mode dynfilefs atau raw\"\n"
"    minios-session create raw 5000                Akan gagal pada FAT32: "
"batas ukuran file adalah 4096MB (4GB)\n"
"\n"
"  Output JSON (untuk otomatisasi):\n"
"    minios-session --json list                    Daftar sesi dalam format "
"JSON\n"
"    minios-session active --json                  Dapatkan informasi sesi "
"aktif dalam format JSON\n"
"    minios-session info --json                    Dapatkan informasi sistem "
"dalam format JSON\n"
"\n"
"  Direktori Sesi Kustom:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create native\n"
"\n"
"        "

