#: lib/minios_session.py:952
msgid ""
"MiniOS Session Manager - Command line tool for managing persistent sessions"
msgstr ""
"MiniOS Session Manager - Alat baris perintah untuk mengelola sesi persisten"

#: lib/minios_session.py:954
msgid ""
"\n"
"GLOBAL OPTIONS:\n"
"  --json                    Output results in JSON format (can be used with "
"any command)\n"
"  --sessions-dir PATH       Use custom sessions directory instead of "
"default\n"
"\n"
"COMMANDS:\n"
"  list                      List all available sessions with detailed "
"information\n"
"  active                    Show currently active session (will boot next)\n"
"  running                   Show currently running session (current boot)\n"
"  info                      Show filesystem type and compatible session "
"modes\n"
"  activate SESSION_ID       Activate specified session (required: "
"session_id)\n"
"  create [OPTIONS]          Create new session (optional: --mode, --size)\n"
"  delete SESSION_ID         Delete specified session (required: session_id)\n"
"  cleanup [OPTIONS]         Delete old sessions (optional: --days, default: "
"30)\n"
"\n"
"SESSION MODES:\n"
"  native                    Direct filesystem changes (requires POSIX-"
"compatible filesystem)\n"
"  dynfilefs                 Dynamic file system overlay (works on any "
"filesystem, 4GB default)\n"
"  raw                       Raw disk image (works on any filesystem, custom "
"size required)\n"
"\n"
"COMMAND BEHAVIOR:\n"
"  • create without --mode: Uses native mode (may fail on FAT32/NTFS)\n"
"  • create without --size: Uses 4000MB (4GB) for dynfilefs/raw modes\n"
"  • cleanup without --days: Uses 30-day threshold for deletion\n"
"  • cleanup protects both active and running sessions from deletion\n"
"\n"
"EXAMPLES:\n"
"\n"
"  Basic Usage:\n"
"    minios-session list                           List all available "
"sessions\n"
"    minios-session active                         Show which session will "
"boot next\n"
"    minios-session running                        Show currently running "
"session\n"
"    minios-session info                           Show filesystem "
"compatibility info\n"
"\n"
"  Session Management:\n"
"    minios-session activate 2                     Set session #2 as default "
"for next boot\n"
"    minios-session delete 3                       Delete session #3 "
"permanently\n"
"    minios-session cleanup --days 30              Delete sessions older than "
"30 days\n"
"    minios-session cleanup                        Delete sessions older than "
"30 days (default)\n"
"\n"
"  Creating Sessions:\n"
"    minios-session create --mode native           Create native session "
"(filesystem changes)\n"
"    minios-session create --mode dynfilefs        Create 4GB dynfilefs "
"session\n"
"    minios-session create --mode dynfilefs --size 8000   Create 8GB "
"dynfilefs session\n"
"    minios-session create --mode raw --size 2000         Create 2GB raw disk "
"image\n"
"\n"
"  Error Handling:\n"
"    minios-session create                         May fail on FAT32: \"Use "
"dynfilefs or raw mode\"\n"
"    minios-session create --mode raw --size 5000 May fail on FAT32: "
"\"Exceeds 4000MB limit\"\n"
"\n"
"  JSON Output (for automation):\n"
"    minios-session --json list                    List sessions in JSON "
"format\n"
"    minios-session active --json                  Get active session info as "
"JSON\n"
"    minios-session info --json                    Get system info as JSON\n"
"\n"
"  Custom Session Directory:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create --mode native\n"
"\n"
"NOTE: Most write operations (activate, create, delete, cleanup) require root "
"privileges.\n"
"      The tool will automatically request privileges when needed.\n"
"        "
msgstr ""
"\n"
"OPSI GLOBAL:\n"
"  --json                    Keluarkan hasil dalam format JSON (dapat "
"digunakan dengan perintah apa pun)\n"
"  --sessions-dir PATH       Gunakan direktori sesi kustom alih-alih default\n"
"\n"
"PERINTAH:\n"
"  list                      Daftar semua sesi yang tersedia dengan informasi "
"detail\n"
"  active                    Tampilkan sesi yang sedang aktif (akan boot "
"berikutnya)\n"
"  running                   Tampilkan sesi yang sedang berjalan (boot "
"saat ini)\n"
"  info                      Tampilkan tipe sistem berkas dan mode sesi "
"yang kompatibel\n"
"  activate SESSION_ID       Aktifkan sesi yang ditentukan (diperlukan: "
"session_id)\n"
"  create [OPSI]             Buat sesi baru (opsional: --mode, --size)\n"
"  delete SESSION_ID         Hapus sesi yang ditentukan (diperlukan: "
"session_id)\n"
"  cleanup [OPSI]            Hapus sesi lama (opsional: --days, default: 30)\n"
"\n"
"MODE SESI:\n"
"  native                    Perubahan sistem berkas langsung (membutuhkan "
"sistem berkas kompatibel POSIX)\n"
"  dynfilefs                 Overlay sistem berkas dinamis (berfungsi pada "
"sistem berkas apa pun, default 4GB)\n"
"  raw                       Citra disk mentah (berfungsi pada sistem berkas "
"apa pun, ukuran kustom diperlukan)\n"
"\n"
"PERILAKU PERINTAH:\n"
"  • create tanpa --mode: Menggunakan mode asli (mungkin gagal pada "
"FAT32/NTFS)\n"
"  • create tanpa --size: Menggunakan 4000MB (4GB) untuk mode dynfilefs/raw\n"
"  • cleanup tanpa --days: Menggunakan ambang batas 30 hari untuk penghapusan\n"
"  • cleanup melindungi sesi aktif dan berjalan dari penghapusan\n"
"\n"
"CONTOH:\n"
"\n"
"  Penggunaan Dasar:\n"
"    minios-session list                           Daftar semua sesi yang "
"tersedia\n"
"    minios-session active                         Tampilkan sesi mana yang "
"akan boot berikutnya\n"
"    minios-session running                        Tampilkan sesi yang sedang "
"berjalan\n"
"    minios-session info                           Tampilkan info "
"kompatibilitas sistem berkas\n"
"\n"
"  Manajemen Sesi:\n"
"    minios-session activate 2                     Atur sesi #2 sebagai default "
"untuk boot berikutnya\n"
"    minios-session delete 3                       Hapus sesi #3 secara "
"permanen\n"
"    minios-session cleanup --days 30              Hapus sesi yang lebih lama "
"dari 30 hari\n"
"    minios-session cleanup                        Hapus sesi yang lebih lama "
"dari 30 hari (default)\n"
"\n"
"  Membuat Sesi:\n"
"    minios-session create --mode native           Buat sesi asli (perubahan "
"sistem berkas)\n"
"    minios-session create --mode dynfilefs        Buat sesi dynfilefs 4GB\n"
"    minios-session create --mode dynfilefs --size 8000   Buat sesi dynfilefs "
"8GB\n"
"    minios-session create --mode raw --size 2000         Buat citra disk "
"mentah 2GB\n"
"\n"
"  Penanganan Kesalahan:\n"
"    minios-session create                         Mungkin gagal pada FAT32: "
"\"Gunakan mode dynfilefs atau raw\"\n"
"    minios-session create --mode raw --size 5000 Mungkin gagal pada FAT32: "
"\"Melebihi batas 4000MB\"\n"
"\n"
"  Output JSON (untuk otomatisasi):\n"
"    minios-session --json list                    Daftar sesi dalam format "
"JSON\n"
"    minios-session active --json                  Dapatkan info sesi aktif "
"sebagai JSON\n"
"    minios-session info --json                    Dapatkan info sistem "
"sebagai JSON\n"
"\n"
"  Direktori Sesi Kustom:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create --mode native\n"
"\n"
"CATATAN: Sebagian besar operasi tulis (aktivasi, buat, hapus, bersihkan) "
"membutuhkan hak akses root.\n"
"      Alat ini akan secara otomatis meminta hak akses bila diperlukan.\n"
"        "

