#: debian/minios-session-manager/usr/lib/minios-session-manager/minios_session.py:2503
#: lib/minios_session.py:2503
msgid "MiniOS Session Manager - Command line tool for managing persistent sessions"
msgstr "Менеджер сессий MiniOS - Утилита командной строки для управления постоянными сессиями"

#: debian/minios-session-manager/usr/lib/minios-session-manager/minios_session.py:2505
#: lib/minios_session.py:2505
msgid ""
"\n"
"GLOBAL OPTIONS:\n"
"  --json                    Output results in JSON format (can be used with any command)\n"
"  --sessions-dir PATH       Use custom sessions directory instead of default\n"
"\n"
"COMMANDS:\n"
"  list                      List all available sessions with detailed information\n"
"  active                    Show currently active session (will boot next)\n"
"  running                   Show currently running session (current boot)\n"
"  info                      Show filesystem type and compatible session modes\n"
"  activate SESSION_ID       Activate specified session\n"
"  create [MODE] [SIZE]      Create new session using positional arguments\n"
"  delete SESSION_ID         Delete specified session\n"
"  cleanup [--days N]        Delete old sessions (default: 30 days)\n"
"  status                    Check sessions directory status and permissions\n"
"  resize SESSION_ID SIZE    Resize session to new size in MB (dynfilefs/raw only)\n"
"  export SESSION_ID PATH    Export session to .tar.zst archive\n"
"  import ARCHIVE            Import session from .tar.zst archive\n"
"  copy SESSION_ID           Copy session (optional: --to-mode, --size)\n"
"  convert SESSION_ID MODE   Convert session to different mode (optional: --size)\n"
"\n"
"SESSION MODES:\n"
"  native                    Direct filesystem changes (requires POSIX-compatible filesystem)\n"
"  dynfilefs                 Dynamic file system overlay (works on any filesystem, 1000MB default)\n"
"  raw                       Raw disk image (works on any filesystem, custom size required)\n"
"\n"
"COMMAND BEHAVIOR:\n"
"  • create without MODE: Uses native mode (may fail on FAT32/NTFS/exFAT)\n"
"  • create without SIZE: Uses 1000MB for dynfilefs/raw modes\n"
"  • cleanup without --days: Uses 30-day threshold for deletion\n"
"  • cleanup protects both active and running sessions from deletion\n"
"\n"
"EXAMPLES:\n"
"\n"
"  Basic Usage:\n"
"    minios-session list                           List all available sessions\n"
"    minios-session active                         Show which session will boot next\n"
"    minios-session running                        Show currently running session\n"
"    minios-session info                           Show filesystem compatibility info\n"
"\n"
"  Session Management:\n"
"    minios-session activate 2                     Set session #2 as default for next boot\n"
"    minios-session delete 3                       Delete session #3 permanently\n"
"    minios-session cleanup --days 30              Delete sessions older than 30 days\n"
"    minios-session cleanup                        Delete sessions older than 30 days (default)\n"
"\n"
"  Creating Sessions:\n"
"    minios-session create                         Create native session (filesystem changes)\n"
"    minios-session create native                  Create native session explicitly\n"
"    minios-session create dynfilefs               Create 1000MB dynfilefs session (default size)\n"
"    minios-session create dynfilefs 8000          Create 8000MB dynfilefs session\n"
"    minios-session create raw 2000                Create 2000MB raw disk image\n"
"\n"
"  Session Operations:\n"
"    minios-session resize 2 4000                  Resize session #2 to 4000MB\n"
"    minios-session export 3 /tmp/backup.tar.zst   Export session #3 to archive\n"
"    minios-session import /tmp/backup.tar.zst     Import session from archive\n"
"    minios-session copy 2                         Copy session #2\n"
"    minios-session copy 2 --to-mode raw --size 3000  Copy session #2 as raw with 3000MB\n"
"    minios-session convert 3 dynfilefs --size 2000   Convert session #3 to dynfilefs with 2000MB\n"
"\n"
"  Error Handling:\n"
"    minios-session create                         May fail on FAT32/NTFS/exFAT: \"Use dynfilefs or raw mode\"\n"
"    minios-session create raw 5000                Will fail on FAT32: file size limit is 4096MB (4GB)\n"
"\n"
"  JSON Output (for automation):\n"
"    minios-session --json list                    List sessions in JSON format\n"
"    minios-session active --json                  Get active session info as JSON\n"
"    minios-session info --json                    Get system info as JSON\n"
"\n"
"  Custom Session Directory:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create native\n"
"\n"
"        "
msgstr ""
"\n"
"ГЛОБАЛЬНЫЕ ОПЦИИ:\n"
"  --json                    Вывод результатов в формате JSON (можно использовать с любой командой)\n"
"  --sessions-dir PATH       Использовать пользовательский каталог сессий вместо стандартного\n"
"\n"
"КОМАНДЫ:\n"
"  list                      Показать все доступные сессии с подробной информацией\n"
"  active                    Показать текущую активную сессию (будет загружена следующей)\n"
"  running                   Показать текущую запущенную сессию (текущая загрузка)\n"
"  info                      Показать тип файловой системы и совместимые режимы сессий\n"
"  activate SESSION_ID       Активировать указанную сессию\n"
"  create [MODE] [SIZE]      Создать новую сессию с использованием позиционных аргументов\n"
"  delete SESSION_ID         Удалить указанную сессию\n"
"  cleanup [--days N]        Удалить старые сессии (по умолчанию: 30 дней)\n"
"  status                    Проверить состояние каталога сессий и права доступа\n"
"  resize SESSION_ID SIZE    Изменить размер сессии до нового значения в МБ (только dynfilefs/raw)\n"
"  export SESSION_ID PATH    Экспортировать сессию в архив .tar.zst\n"
"  import ARCHIVE            Импортировать сессию из архива .tar.zst\n"
"  copy SESSION_ID           Копировать сессию (опционально: --to-mode, --size)\n"
"  convert SESSION_ID MODE   Конвертировать сессию в другой режим (опционально: --size)\n"
"\n"
"РЕЖИМЫ СЕССИЙ:\n"
"  native                    Прямые изменения файловой системы (требуется POSIX-совместимая файловая система)\n"
"  dynfilefs                 Динамическая файловая система (работает на любой файловой системе, по умолчанию 1000 МБ)\n"
"  raw                       Образ диска (работает на любой файловой системе, требуется указание размера)\n"
"\n"
"ПОВЕДЕНИЕ КОМАНД:\n"
"  • create без MODE: Используется режим native (может не работать на FAT32/NTFS/exFAT)\n"
"  • create без SIZE: Используется 1000 МБ для режимов dynfilefs/raw\n"
"  • cleanup без --days: Используется порог в 30 дней для удаления\n"
"  • cleanup защищает как активные, так и запущенные сессии от удаления\n"
"\n"
"ПРИМЕРЫ:\n"
"\n"
"  Основное использование:\n"
"    minios-session list                           Показать все доступные сессии\n"
"    minios-session active                         Показать, какая сессия будет загружена следующей\n"
"    minios-session running                        Показать текущую запущенную сессию\n"
"    minios-session info                           Показать информацию о совместимости файловой системы\n"
"\n"
"  Управление сессиями:\n"
"    minios-session activate 2                     Установить сессию №2 как стандартную для следующей загрузки\n"
"    minios-session delete 3                       Удалить сессию №3 навсегда\n"
"    minios-session cleanup --days 30              Удалить сессии старше 30 дней\n"
"    minios-session cleanup                        Удалить сессии старше 30 дней (по умолчанию)\n"
"\n"
"  Создание сессий:\n"
"    minios-session create                         Создать сессию в режиме native (изменения файловой системы)\n"
"    minios-session create native                  Явно создать сессию в режиме native\n"
"    minios-session create dynfilefs               Создать сессию dynfilefs размером 1000 МБ (по умолчанию)\n"
"    minios-session create dynfilefs 8000          Создать сессию dynfilefs размером 8000 МБ\n"
"    minios-session create raw 2000                Создать образ диска raw размером 2000 МБ\n"
"\n"
"  Операции с сессиями:\n"
"    minios-session resize 2 4000                  Изменить размер сессии №2 до 4000 МБ\n"
"    minios-session export 3 /tmp/backup.tar.zst   Экспортировать сессию №3 в архив\n"
"    minios-session import /tmp/backup.tar.zst     Импортировать сессию из архива\n"
"    minios-session copy 2                         Копировать сессию №2\n"
"    minios-session copy 2 --to-mode raw --size 3000  Копировать сессию №2 в режиме raw размером 3000 МБ\n"
"    minios-session convert 3 dynfilefs --size 2000   Конвертировать сессию №3 в режим dynfilefs размером 2000 МБ\n"
"\n"
"  Обработка ошибок:\n"
"    minios-session create                         Может не работать на FAT32/NTFS/exFAT: \"Используйте режим dynfilefs или raw\"\n"
"    minios-session create raw 5000                Не будет работать на FAT32: ограничение размера файла 4096 МБ (4 ГБ)\n"
"\n"
"  Вывод JSON (для автоматизации):\n"
"    minios-session --json list                    Показать сессии в формате JSON\n"
"    minios-session active --json                  Получить информацию об активной сессии в формате JSON\n"
"    minios-session info --json                    Получить системную информацию в формате JSON\n"
"\n"
"  Пользовательский каталог сессий:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create native\n"
"\n"
"        "

