#: lib/minios_session.py:952
msgid ""
"MiniOS Session Manager - Command line tool for managing persistent sessions"
msgstr ""
"Менеджер сессий MiniOS - Утилита командной строки для управления постоянными "
"сессиями"

#: lib/minios_session.py:954
msgid ""
"\n"
"GLOBAL OPTIONS:\n"
"  --json                    Output results in JSON format (can be used with "
"any command)\n"
"  --sessions-dir PATH       Use custom sessions directory instead of "
"default\n"
"\n"
"COMMANDS:\n"
"  list                      List all available sessions with detailed "
"information\n"
"  active                    Show currently active session (will boot next)\n"
"  running                   Show currently running session (current boot)\n"
"  info                      Show filesystem type and compatible session "
"modes\n"
"  activate SESSION_ID       Activate specified session (required: "
"session_id)\n"
"  create [OPTIONS]          Create new session (optional: --mode, --size)\n"
"  delete SESSION_ID         Delete specified session (required: session_id)\n"
"  cleanup [OPTIONS]         Delete old sessions (optional: --days, default: "
"30)\n"
"\n"
"SESSION MODES:\n"
"  native                    Direct filesystem changes (requires POSIX-"
"compatible filesystem)\n"
"  dynfilefs                 Dynamic file system overlay (works on any "
"filesystem, 4GB default)\n"
"  raw                       Raw disk image (works on any filesystem, custom "
"size required)\n"
"\n"
"COMMAND BEHAVIOR:\n"
"  • create without --mode: Uses native mode (may fail on FAT32/NTFS)\n"
"  • create without --size: Uses 4000MB (4GB) for dynfilefs/raw modes\n"
"  • cleanup without --days: Uses 30-day threshold for deletion\n"
"  • cleanup protects both active and running sessions from deletion\n"
"\n"
"EXAMPLES:\n"
"\n"
"  Basic Usage:\n"
"    minios-session list                           List all available "
"sessions\n"
"    minios-session active                         Show which session will "
"boot next\n"
"    minios-session running                        Show currently running "
"session\n"
"    minios-session info                           Show filesystem "
"compatibility info\n"
"\n"
"  Session Management:\n"
"    minios-session activate 2                     Set session #2 as default "
"for next boot\n"
"    minios-session delete 3                       Delete session #3 "
"permanently\n"
"    minios-session cleanup --days 30              Delete sessions older than "
"30 days\n"
"    minios-session cleanup                        Delete sessions older than "
"30 days (default)\n"
"\n"
"  Creating Sessions:\n"
"    minios-session create --mode native           Create native session "
"(filesystem changes)\n"
"    minios-session create --mode dynfilefs        Create 4GB dynfilefs "
"session\n"
"    minios-session create --mode dynfilefs --size 8000   Create 8GB "
"dynfilefs session\n"
"    minios-session create --mode raw --size 2000         Create 2GB raw disk "
"image\n"
"\n"
"  Error Handling:\n"
"    minios-session create                         May fail on FAT32: \"Use "
"dynfilefs or raw mode\"\n"
"    minios-session create --mode raw --size 5000 May fail on FAT32: "
"\"Exceeds 4000MB limit\"\n"
"\n"
"  JSON Output (for automation):\n"
"    minios-session --json list                    List sessions in JSON "
"format\n"
"    minios-session active --json                  Get active session info as "
"JSON\n"
"    minios-session info --json                    Get system info as JSON\n"
"\n"
"  Custom Session Directory:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create --mode native\n"
"\n"
"NOTE: Most write operations (activate, create, delete, cleanup) require root "
"privileges.\n"
"      The tool will automatically request privileges when needed.\n"
"        "
msgstr ""
"\n"
"ГЛОБАЛЬНЫЕ ОПЦИИ:\n"
"  --json                    Выводить результаты в формате JSON (можно "
"использовать с любой командой)\n"
"  --sessions-dir PATH       Использовать пользовательский каталог сессий "
"вместо стандартного\n"
"\n"
"КОМАНДЫ:\n"
"  list                      Показать все доступные сессии с подробной "
"информацией\n"
"  active                    Показать текущую активную сессию (будет "
"загружена следующей)\n"
"  running                   Показать текущую запущенную сессию (текущая "
"загрузка)\n"
"  info                      Показать тип файловой системы и совместимые "
"режимы сессий\n"
"  activate SESSION_ID       Активировать указанную сессию (обязательно: "
"session_id)\n"
"  create [ОПЦИИ]            Создать новую сессию (опционально: --mode, --size)\n"
"  delete SESSION_ID         Удалить указанную сессию (обязательно: "
"session_id)\n"
"  cleanup [ОПЦИИ]           Удалить старые сессии (опционально: --days, по "
"умолчанию: 30)\n"
"\n"
"РЕЖИМЫ СЕССИЙ:\n"
"  native                    Прямые изменения файловой системы (требует "
"POSIX-совместимой файловой системы)\n"
"  dynfilefs                 Динамический оверлей файловой системы "
"(работает на любой файловой системе, по умолчанию 4ГБ)\n"
"  raw                       Образ raw-диска (работает на любой файловой "
"системе, требуется указание размера)\n"
"\n"
"ПОВЕДЕНИЕ КОМАНД:\n"
"  • create без --mode: Использует нативный режим (может не работать на "
"FAT32/NTFS)\n"
"  • create без --size: Использует 4000МБ (4ГБ) для режимов dynfilefs/raw\n"
"  • cleanup без --days: Использует порог в 30 дней для удаления\n"
"  • cleanup защищает активные и запущенные сессии от удаления\n"
"\n"
"ПРИМЕРЫ:\n"
"\n"
"  Базовое использование:\n"
"    minios-session list                           Показать все доступные "
"сессии\n"
"    minios-session active                         Показать, какая сессия "
"будет загружена следующей\n"
"    minios-session running                        Показать текущую "
"запущенную сессию\n"
"    minios-session info                           Показать информацию о "
"совместимости файловой системы\n"
"\n"
"  Управление сессиями:\n"
"    minios-session activate 2                     Установить сессию #2 как "
"активную для следующей загрузки\n"
"    minios-session delete 3                       Удалить сессию #3 "
"навсегда\n"
"    minios-session cleanup --days 30              Удалить сессии старше 30 "
"дней\n"
"    minios-session cleanup                        Удалить сессии старше 30 "
"дней (по умолчанию)\n"
"\n"
"  Создание сессий:\n"
"    minios-session create --mode native           Создать нативную сессию "
"(изменения файловой системы)\n"
"    minios-session create --mode dynfilefs        Создать сессию dynfilefs "
"на 4ГБ\n"
"    minios-session create --mode dynfilefs --size 8000   Создать сессию "
"dynfilefs на 8ГБ\n"
"    minios-session create --mode raw --size 2000         Создать образ "
"raw-диска на 2ГБ\n"
"\n"
"  Обработка ошибок:\n"
"    minios-session create                         Может не работать на FAT32:"
" \"Используйте режим dynfilefs или raw\"\n"
"    minios-session create --mode raw --size 5000 Может не работать на FAT32: "
"\"Превышает лимит 4000МБ\"\n"
"\n"
"  Вывод JSON (для автоматизации):\n"
"    minios-session --json list                    Показать сессии в формате "
"JSON\n"
"    minios-session active --json                  Получить информацию об "
"активной сессии в формате JSON\n"
"    minios-session info --json                    Получить информацию о "
"системе в формате JSON\n"
"\n"
"  Пользовательский каталог сессий:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create --mode native\n"
"\n"
"ПРИМЕЧАНИЕ: Большинство операций записи (активация, создание, удаление, "
"очистка) требуют привилегий root.\n"
"      Инструмент автоматически запросит привилегии при необходимости.\n"
"        "

