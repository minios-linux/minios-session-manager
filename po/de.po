#: lib/minios_session.py:952
msgid ""
"MiniOS Session Manager - Command line tool for managing persistent sessions"
msgstr ""
"MiniOS Session Manager - Kommandozeilen-Tool zur Verwaltung persistenter "
"Sitzungen"

#: lib/minios_session.py:954
msgid ""
"\n"
"GLOBAL OPTIONS:\n"
"  --json                    Output results in JSON format (can be used with "
"any command)\n"
"  --sessions-dir PATH       Use custom sessions directory instead of "
"default\n"
"\n"
"COMMANDS:\n"
"  list                      List all available sessions with detailed "
"information\n"
"  active                    Show currently active session (will boot next)\n"
"  running                   Show currently running session (current boot)\n"
"  info                      Show filesystem type and compatible session "
"modes\n"
"  activate SESSION_ID       Activate specified session (required: "
"session_id)\n"
"  create [OPTIONS]          Create new session (optional: --mode, --size)\n"
"  delete SESSION_ID         Delete specified session (required: session_id)\n"
"  cleanup [OPTIONS]         Delete old sessions (optional: --days, default: "
"30)\n"
"\n"
"SESSION MODES:\n"
"  native                    Direct filesystem changes (requires POSIX-"
"compatible filesystem)\n"
"  dynfilefs                 Dynamic file system overlay (works on any "
"filesystem, 4GB default)\n"
"  raw                       Raw disk image (works on any filesystem, custom "
"size required)\n"
"\n"
"COMMAND BEHAVIOR:\n"
"  • create without --mode: Uses native mode (may fail on FAT32/NTFS)\n"
"  • create without --size: Uses 4000MB (4GB) for dynfilefs/raw modes\n"
"  • cleanup without --days: Uses 30-day threshold for deletion\n"
"  • cleanup protects both active and running sessions from deletion\n"
"\n"
"EXAMPLES:\n"
"\n"
"  Basic Usage:\n"
"    minios-session list                           List all available "
"sessions\n"
"    minios-session active                         Show which session will "
"boot next\n"
"    minios-session running                        Show currently running "
"session\n"
"    minios-session info                           Show filesystem "
"compatibility info\n"
"\n"
"  Session Management:\n"
"    minios-session activate 2                     Set session #2 as default "
"for next boot\n"
"    minios-session delete 3                       Delete session #3 "
"permanently\n"
"    minios-session cleanup --days 30              Delete sessions older than "
"30 days\n"
"    minios-session cleanup                        Delete sessions older than "
"30 days (default)\n"
"\n"
"  Creating Sessions:\n"
"    minios-session create --mode native           Create native session "
"(filesystem changes)\n"
"    minios-session create --mode dynfilefs        Create 4GB dynfilefs "
"session\n"
"    minios-session create --mode dynfilefs --size 8000   Create 8GB "
"dynfilefs session\n"
"    minios-session create --mode raw --size 2000         Create 2GB raw disk "
"image\n"
"\n"
"  Error Handling:\n"
"    minios-session create                         May fail on FAT32: \"Use "
"dynfilefs or raw mode\"\n"
"    minios-session create --mode raw --size 5000 May fail on FAT32: "
"\"Exceeds 4000MB limit\"\n"
"\n"
"  JSON Output (for automation):\n"
"    minios-session --json list                    List sessions in JSON "
"format\n"
"    minios-session active --json                  Get active session info as "
"JSON\n"
"    minios-session info --json                    Get system info as JSON\n"
"\n"
"  Custom Session Directory:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create --mode native\n"
"\n"
"NOTE: Most write operations (activate, create, delete, cleanup) require root "
"privileges.\n"
"      The tool will automatically request privileges when needed.\n"
"        "
msgstr ""
"\n"
"GLOBALE OPTIONEN:\n"
"  --json                    Ergebnisse im JSON-Format ausgeben (kann mit "
"jedem Befehl verwendet werden)\n"
"  --sessions-dir PFAD       Benutzerdefiniertes Sitzungsverzeichnis anstelle "
"des Standards verwenden\n"
"\n"
"BEFEHLE:\n"
"  list                      Alle verfügbaren Sitzungen mit detaillierten "
"Informationen auflisten\n"
"  active                    Aktuell aktive Sitzung anzeigen (wird als "
"nächstes gestartet)\n"
"  running                   Aktuell laufende Sitzung anzeigen (aktueller "
"Start)\n"
"  info                      Dateisystemtyp und kompatible Sitzungsmodi "
"anzeigen\n"
"  activate SITZUNGS-ID      Angegebene Sitzung aktivieren (erforderlich: "
"sitzungs_id)\n"
"  create [OPTIONEN]         Neue Sitzung erstellen (optional: --mode, --"
"size)\n"
"  delete SITZUNGS-ID        Angegebene Sitzung löschen (erforderlich: "
"sitzungs_id)\n"
"  cleanup [OPTIONEN]        Alte Sitzungen löschen (optional: --days, "
"Standard: 30)\n"
"\n"
"SITZUNGSMODI:\n"
"  native                    Direkte Dateisystemänderungen (erfordert POSIX-"
"kompatibles Dateisystem)\n"
"  dynfilefs                 Dynamisches Dateisystem-Overlay (funktioniert "
"auf jedem Dateisystem, 4 GB Standard)\n"
"  raw                       Raw-Disk-Image (funktioniert auf jedem "
"Dateisystem, benutzerdefinierte Größe erforderlich)\n"
"\n"
"BEFEHLSVERHALTEN:\n"
"  • create ohne --mode: Verwendet den nativen Modus (kann auf FAT32/NTFS "
"fehlschlagen)\n"
"  • create ohne --size: Verwendet 4000 MB (4 GB) für die Modi dynfilefs/raw\n"
"  • cleanup ohne --days: Verwendet eine 30-Tage-Schwelle zum Löschen\n"
"  • cleanup schützt sowohl aktive als auch laufende Sitzungen vor dem "
"Löschen\n"
"\n"
"BEISPIELE:\n"
"\n"
"  Grundlegende Verwendung:\n"
"    minios-session list                           Alle verfügbaren Sitzungen "
"auflisten\n"
"    minios-session active                         Anzeigen, welche Sitzung "
"als nächstes gestartet wird\n"
"    minios-session running                        Aktuell laufende Sitzung "
"anzeigen\n"
"    minios-session info                           Informationen zur "
"Dateisystemkompatibilität anzeigen\n"
"\n"
"  Sitzungsverwaltung:\n"
"    minios-session activate 2                     Sitzung #2 als Standard "
"für den nächsten Start festlegen\n"
"    minios-session delete 3                       Sitzung #3 dauerhaft "
"löschen\n"
"    minios-session cleanup --days 30              Sitzungen löschen, die "
"älter als 30 Tage sind\n"
"    minios-session cleanup                        Sitzungen löschen, die "
"älter als 30 Tage sind (Standard)\n"
"\n"
"  Sitzungen erstellen:\n"
"    minios-session create --mode native           Native Sitzung erstellen "
"(Dateisystemänderungen)\n"
"    minios-session create --mode dynfilefs        4-GB-dynfilefs-Sitzung "
"erstellen\n"
"    minios-session create --mode dynfilefs --size 8000   8-GB-dynfilefs-"
"Sitzung erstellen\n"
"    minios-session create --mode raw --size 2000         2-GB-Raw-Disk-Image "
"erstellen\n"
"\n"
"  Fehlerbehandlung:\n"
"    minios-session create                         Kann auf FAT32 "
"fehlschlagen: \"Verwenden Sie den dynfilefs- oder Raw-Modus\"\n"
"    minios-session create --mode raw --size 5000 Kann auf FAT32 "
"fehlschlagen: \"Überschreitet das 4000-MB-Limit\"\n"
"\n"
"  JSON-Ausgabe (für die Automatisierung):\n"
"    minios-session --json list                    Sitzungen im JSON-Format "
"auflisten\n"
"    minios-session active --json                  Informationen zur aktiven "
"Sitzung als JSON abrufen\n"
"    minios-session info --json                    Systeminformationen als "
"JSON abrufen\n"
"\n"
"  Benutzerdefiniertes Sitzungsverzeichnis:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create --mode native\n"
"\n"
"HINWEIS: Die meisten Schreibvorgänge (activate, create, delete, cleanup) "
"erfordern Root-Rechte.\n"
"      Das Tool fordert bei Bedarf automatisch Berechtigungen an.\n"
"        "

