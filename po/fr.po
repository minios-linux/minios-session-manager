#: lib/minios_session.py:2503
msgid ""
"MiniOS Session Manager - Command line tool for managing persistent sessions"
msgstr ""
"Gestionnaire de sessions MiniOS - Outil en ligne de commande pour la gestion "
"des sessions persistantes"

#: lib/minios_session.py:2505
msgid ""
"\n"
"GLOBAL OPTIONS:\n"
"  --json                    Output results in JSON format (can be used with "
"any command)\n"
"  --sessions-dir PATH       Use custom sessions directory instead of "
"default\n"
"\n"
"COMMANDS:\n"
"  list                      List all available sessions with detailed "
"information\n"
"  active                    Show currently active session (will boot next)\n"
"  running                   Show currently running session (current boot)\n"
"  info                      Show filesystem type and compatible session "
"modes\n"
"  activate SESSION_ID       Activate specified session\n"
"  create [MODE] [SIZE]      Create new session using positional arguments\n"
"  delete SESSION_ID         Delete specified session\n"
"  cleanup [--days N]        Delete old sessions (default: 30 days)\n"
"  status                    Check sessions directory status and permissions\n"
"  resize SESSION_ID SIZE    Resize session to new size in MB (dynfilefs/raw "
"only)\n"
"  export SESSION_ID PATH    Export session to .tar.zst archive\n"
"  import ARCHIVE            Import session from .tar.zst archive\n"
"  copy SESSION_ID           Copy session (optional: --to-mode, --size)\n"
"  convert SESSION_ID MODE   Convert session to different mode (optional: --"
"size)\n"
"\n"
"SESSION MODES:\n"
"  native                    Direct filesystem changes (requires POSIX-"
"compatible filesystem)\n"
"  dynfilefs                 Dynamic file system overlay (works on any "
"filesystem, 1000MB default)\n"
"  raw                       Raw disk image (works on any filesystem, custom "
"size required)\n"
"\n"
"COMMAND BEHAVIOR:\n"
"  • create without MODE: Uses native mode (may fail on FAT32/NTFS/exFAT)\n"
"  • create without SIZE: Uses 1000MB for dynfilefs/raw modes\n"
"  • cleanup without --days: Uses 30-day threshold for deletion\n"
"  • cleanup protects both active and running sessions from deletion\n"
"\n"
"EXAMPLES:\n"
"\n"
"  Basic Usage:\n"
"    minios-session list                           List all available "
"sessions\n"
"    minios-session active                         Show which session will "
"boot next\n"
"    minios-session running                        Show currently running "
"session\n"
"    minios-session info                           Show filesystem "
"compatibility info\n"
"\n"
"  Session Management:\n"
"    minios-session activate 2                     Set session #2 as default "
"for next boot\n"
"    minios-session delete 3                       Delete session #3 "
"permanently\n"
"    minios-session cleanup --days 30              Delete sessions older than "
"30 days\n"
"    minios-session cleanup                        Delete sessions older than "
"30 days (default)\n"
"\n"
"  Creating Sessions:\n"
"    minios-session create                         Create native session "
"(filesystem changes)\n"
"    minios-session create native                  Create native session "
"explicitly\n"
"    minios-session create dynfilefs               Create 1000MB dynfilefs "
"session (default size)\n"
"    minios-session create dynfilefs 8000          Create 8000MB dynfilefs "
"session\n"
"    minios-session create raw 2000                Create 2000MB raw disk "
"image\n"
"\n"
"  Session Operations:\n"
"    minios-session resize 2 4000                  Resize session #2 to "
"4000MB\n"
"    minios-session export 3 /tmp/backup.tar.zst   Export session #3 to "
"archive\n"
"    minios-session import /tmp/backup.tar.zst     Import session from "
"archive\n"
"    minios-session copy 2                         Copy session #2\n"
"    minios-session copy 2 --to-mode raw --size 3000  Copy session #2 as raw "
"with 3000MB\n"
"    minios-session convert 3 dynfilefs --size 2000   Convert session #3 to "
"dynfilefs with 2000MB\n"
"\n"
"  Error Handling:\n"
"    minios-session create                         May fail on FAT32/NTFS/"
"exFAT: \"Use dynfilefs or raw mode\"\n"
"    minios-session create raw 5000                Will fail on FAT32: file "
"size limit is 4096MB (4GB)\n"
"\n"
"  JSON Output (for automation):\n"
"    minios-session --json list                    List sessions in JSON "
"format\n"
"    minios-session active --json                  Get active session info as "
"JSON\n"
"    minios-session info --json                    Get system info as JSON\n"
"\n"
"  Custom Session Directory:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create native\n"
"\n"
"        "
msgstr ""
"\n"
"OPTIONS GLOBALES :\n"
"  --json                    Afficher les résultats au format JSON (peut être "
"utilisé avec n'importe quelle commande)\n"
"  --sessions-dir PATH       Utiliser un répertoire de sessions personnalisé "
"au lieu de celui par défaut\n"
"\n"
"COMMANDES :\n"
"  list                      Lister toutes les sessions disponibles avec des "
"informations détaillées\n"
"  active                    Afficher la session actuellement active (sera "
"démarrée ensuite)\n"
"  running                   Afficher la session actuellement en cours "
"d'exécution (démarrage actuel)\n"
"  info                      Afficher le type de système de fichiers et les "
"modes de session compatibles\n"
"  activate SESSION_ID       Activer la session spécifiée\n"
"  create [MODE] [SIZE]      Créer une nouvelle session en utilisant des "
"arguments positionnels\n"
"  delete SESSION_ID         Supprimer la session spécifiée\n"
"  cleanup [--days N]        Supprimer les anciennes sessions (par défaut : "
"30 jours)\n"
"  status                    Vérifier l'état et les permissions du répertoire "
"des sessions\n"
"  resize SESSION_ID SIZE    Redimensionner la session à une nouvelle taille "
"en Mo (dynfilefs/raw uniquement)\n"
"  export SESSION_ID PATH    Exporter la session vers une archive .tar.zst\n"
"  import ARCHIVE            Importer une session depuis une "
"archive .tar.zst\n"
"  copy SESSION_ID           Copier une session (optionnel : --to-mode, --"
"size)\n"
"  convert SESSION_ID MODE   Convertir une session vers un autre mode "
"(optionnel : --size)\n"
"\n"
"MODES DE SESSION :\n"
"  native                    Modifications directes du système de fichiers "
"(nécessite un système de fichiers compatible POSIX)\n"
"  dynfilefs                 Système de fichiers dynamique (fonctionne sur "
"tout système de fichiers, 1000 Mo par défaut)\n"
"  raw                       Image disque brute (fonctionne sur tout système "
"de fichiers, taille personnalisée requise)\n"
"\n"
"COMPORTEMENT DES COMMANDES :\n"
"  • create sans MODE : Utilise le mode native (peut échouer sur FAT32/NTFS/"
"exFAT)\n"
"  • create sans SIZE : Utilise 1000 Mo pour les modes dynfilefs/raw\n"
"  • cleanup sans --days : Utilise un seuil de 30 jours pour la suppression\n"
"  • cleanup protège les sessions actives et en cours d'exécution de la "
"suppression\n"
"\n"
"EXEMPLES :\n"
"\n"
"  Utilisation de base :\n"
"    minios-session list                           Lister toutes les sessions "
"disponibles\n"
"    minios-session active                         Afficher quelle session "
"sera démarrée ensuite\n"
"    minios-session running                        Afficher la session "
"actuellement en cours d'exécution\n"
"    minios-session info                           Afficher les informations "
"de compatibilité du système de fichiers\n"
"\n"
"  Gestion des sessions :\n"
"    minios-session activate 2                     Définir la session n°2 "
"comme session par défaut pour le prochain démarrage\n"
"    minios-session delete 3                       Supprimer définitivement "
"la session n°3\n"
"    minios-session cleanup --days 30              Supprimer les sessions de "
"plus de 30 jours\n"
"    minios-session cleanup                        Supprimer les sessions de "
"plus de 30 jours (par défaut)\n"
"\n"
"  Création de sessions :\n"
"    minios-session create                         Créer une session native "
"(modifications du système de fichiers)\n"
"    minios-session create native                  Créer explicitement une "
"session native\n"
"    minios-session create dynfilefs               Créer une session "
"dynfilefs de 1000 Mo (taille par défaut)\n"
"    minios-session create dynfilefs 8000          Créer une session "
"dynfilefs de 8000 Mo\n"
"    minios-session create raw 2000                Créer une image disque "
"brute de 2000 Mo\n"
"\n"
"  Opérations sur les sessions :\n"
"    minios-session resize 2 4000                  Redimensionner la session "
"n°2 à 4000 Mo\n"
"    minios-session export 3 /tmp/backup.tar.zst   Exporter la session n°3 "
"vers une archive\n"
"    minios-session import /tmp/backup.tar.zst     Importer une session "
"depuis une archive\n"
"    minios-session copy 2                         Copier la session n°2\n"
"    minios-session copy 2 --to-mode raw --size 3000  Copier la session n°2 "
"en mode raw avec 3000 Mo\n"
"    minios-session convert 3 dynfilefs --size 2000   Convertir la session "
"n°3 en dynfilefs avec 2000 Mo\n"
"\n"
"  Gestion des erreurs :\n"
"    minios-session create                         Peut échouer sur FAT32/"
"NTFS/exFAT : \"Utilisez le mode dynfilefs ou raw\"\n"
"    minios-session create raw 5000                Échouera sur FAT32 : "
"limite de taille de fichier de 4096 Mo (4 Go)\n"
"\n"
"  Sortie JSON (pour l'automatisation) :\n"
"    minios-session --json list                    Lister les sessions au "
"format JSON\n"
"    minios-session active --json                  Obtenir les informations "
"de la session active au format JSON\n"
"    minios-session info --json                    Obtenir les informations "
"système au format JSON\n"
"\n"
"  Répertoire de sessions personnalisé :\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create native\n"
"\n"
"        "

