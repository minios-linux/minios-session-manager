#: lib/minios_session.py:2503
msgid ""
"MiniOS Session Manager - Command line tool for managing persistent sessions"
msgstr ""
"Gestor de Sessões MiniOS - Ferramenta de linha de comando para gerir sessões "
"persistentes"

#: lib/minios_session.py:2505
msgid ""
"\n"
"GLOBAL OPTIONS:\n"
"  --json                    Output results in JSON format (can be used with "
"any command)\n"
"  --sessions-dir PATH       Use custom sessions directory instead of "
"default\n"
"\n"
"COMMANDS:\n"
"  list                      List all available sessions with detailed "
"information\n"
"  active                    Show currently active session (will boot next)\n"
"  running                   Show currently running session (current boot)\n"
"  info                      Show filesystem type and compatible session "
"modes\n"
"  activate SESSION_ID       Activate specified session\n"
"  create [MODE] [SIZE]      Create new session using positional arguments\n"
"  delete SESSION_ID         Delete specified session\n"
"  cleanup [--days N]        Delete old sessions (default: 30 days)\n"
"  status                    Check sessions directory status and permissions\n"
"  resize SESSION_ID SIZE    Resize session to new size in MB (dynfilefs/raw "
"only)\n"
"  export SESSION_ID PATH    Export session to .tar.zst archive\n"
"  import ARCHIVE            Import session from .tar.zst archive\n"
"  copy SESSION_ID           Copy session (optional: --to-mode, --size)\n"
"  convert SESSION_ID MODE   Convert session to different mode (optional: --"
"size)\n"
"\n"
"SESSION MODES:\n"
"  native                    Direct filesystem changes (requires POSIX-"
"compatible filesystem)\n"
"  dynfilefs                 Dynamic file system overlay (works on any "
"filesystem, 1000MB default)\n"
"  raw                       Raw disk image (works on any filesystem, custom "
"size required)\n"
"\n"
"COMMAND BEHAVIOR:\n"
"  • create without MODE: Uses native mode (may fail on FAT32/NTFS/exFAT)\n"
"  • create without SIZE: Uses 1000MB for dynfilefs/raw modes\n"
"  • cleanup without --days: Uses 30-day threshold for deletion\n"
"  • cleanup protects both active and running sessions from deletion\n"
"\n"
"EXAMPLES:\n"
"\n"
"  Basic Usage:\n"
"    minios-session list                           List all available "
"sessions\n"
"    minios-session active                         Show which session will "
"boot next\n"
"    minios-session running                        Show currently running "
"session\n"
"    minios-session info                           Show filesystem "
"compatibility info\n"
"\n"
"  Session Management:\n"
"    minios-session activate 2                     Set session #2 as default "
"for next boot\n"
"    minios-session delete 3                       Delete session #3 "
"permanently\n"
"    minios-session cleanup --days 30              Delete sessions older than "
"30 days\n"
"    minios-session cleanup                        Delete sessions older than "
"30 days (default)\n"
"\n"
"  Creating Sessions:\n"
"    minios-session create                         Create native session "
"(filesystem changes)\n"
"    minios-session create native                  Create native session "
"explicitly\n"
"    minios-session create dynfilefs               Create 1000MB dynfilefs "
"session (default size)\n"
"    minios-session create dynfilefs 8000          Create 8000MB dynfilefs "
"session\n"
"    minios-session create raw 2000                Create 2000MB raw disk "
"image\n"
"\n"
"  Session Operations:\n"
"    minios-session resize 2 4000                  Resize session #2 to "
"4000MB\n"
"    minios-session export 3 /tmp/backup.tar.zst   Export session #3 to "
"archive\n"
"    minios-session import /tmp/backup.tar.zst     Import session from "
"archive\n"
"    minios-session copy 2                         Copy session #2\n"
"    minios-session copy 2 --to-mode raw --size 3000  Copy session #2 as raw "
"with 3000MB\n"
"    minios-session convert 3 dynfilefs --size 2000   Convert session #3 to "
"dynfilefs with 2000MB\n"
"\n"
"  Error Handling:\n"
"    minios-session create                         May fail on FAT32/NTFS/"
"exFAT: \"Use dynfilefs or raw mode\"\n"
"    minios-session create raw 5000                Will fail on FAT32: file "
"size limit is 4096MB (4GB)\n"
"\n"
"  JSON Output (for automation):\n"
"    minios-session --json list                    List sessions in JSON "
"format\n"
"    minios-session active --json                  Get active session info as "
"JSON\n"
"    minios-session info --json                    Get system info as JSON\n"
"\n"
"  Custom Session Directory:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create native\n"
"\n"
"        "
msgstr ""
"\n"
"OPÇÕES GLOBAIS:\n"
"  --json                    Exibir resultados no formato JSON (pode ser "
"usado com qualquer comando)\n"
"  --sessions-dir PATH       Usar diretório de sessões personalizado em vez "
"do padrão\n"
"\n"
"COMANDOS:\n"
"  list                      Listar todas as sessões disponíveis com "
"informações detalhadas\n"
"  active                    Mostrar a sessão atualmente ativa (será "
"inicializada na próxima vez)\n"
"  running                   Mostrar a sessão atualmente em execução "
"(inicialização atual)\n"
"  info                      Mostrar tipo de sistema de arquivos e modos de "
"sessão compatíveis\n"
"  activate SESSION_ID       Ativar a sessão especificada\n"
"  create [MODE] [SIZE]      Criar nova sessão usando argumentos posicionais\n"
"  delete SESSION_ID         Excluir a sessão especificada\n"
"  cleanup [--days N]        Excluir sessões antigas (padrão: 30 dias)\n"
"  status                    Verificar status e permissões do diretório de "
"sessões\n"
"  resize SESSION_ID SIZE    Redimensionar a sessão para um novo tamanho em "
"MB (somente dynfilefs/raw)\n"
"  export SESSION_ID PATH    Exportar sessão para um arquivo .tar.zst\n"
"  import ARCHIVE            Importar sessão de um arquivo .tar.zst\n"
"  copy SESSION_ID           Copiar sessão (opcional: --to-mode, --size)\n"
"  convert SESSION_ID MODE   Converter sessão para outro modo (opcional: --"
"size)\n"
"\n"
"MODOS DE SESSÃO:\n"
"  native                    Alterações diretas no sistema de arquivos "
"(requer sistema de arquivos compatível com POSIX)\n"
"  dynfilefs                 Sobreposição de sistema de arquivos dinâmico "
"(funciona em qualquer sistema de arquivos, padrão de 1000MB)\n"
"  raw                       Imagem de disco bruto (funciona em qualquer "
"sistema de arquivos, tamanho personalizado necessário)\n"
"\n"
"COMPORTAMENTO DOS COMANDOS:\n"
"  • create sem MODE: Usa o modo native (pode falhar em FAT32/NTFS/exFAT)\n"
"  • create sem SIZE: Usa 1000MB para os modos dynfilefs/raw\n"
"  • cleanup sem --days: Usa limite de 30 dias para exclusão\n"
"  • cleanup protege tanto as sessões ativas quanto as em execução contra "
"exclusão\n"
"\n"
"EXEMPLOS:\n"
"\n"
"  Uso Básico:\n"
"    minios-session list                           Listar todas as sessões "
"disponíveis\n"
"    minios-session active                         Mostrar qual sessão será "
"inicializada na próxima vez\n"
"    minios-session running                        Mostrar a sessão "
"atualmente em execução\n"
"    minios-session info                           Mostrar informações de "
"compatibilidade do sistema de arquivos\n"
"\n"
"  Gerenciamento de Sessões:\n"
"    minios-session activate 2                     Definir a sessão #2 como "
"padrão para a próxima inicialização\n"
"    minios-session delete 3                       Excluir permanentemente a "
"sessão #3\n"
"    minios-session cleanup --days 30              Excluir sessões mais "
"antigas que 30 dias\n"
"    minios-session cleanup                        Excluir sessões mais "
"antigas que 30 dias (padrão)\n"
"\n"
"  Criação de Sessões:\n"
"    minios-session create                         Criar sessão native "
"(alterações no sistema de arquivos)\n"
"    minios-session create native                  Criar sessão native "
"explicitamente\n"
"    minios-session create dynfilefs               Criar sessão dynfilefs de "
"1000MB (tamanho padrão)\n"
"    minios-session create dynfilefs 8000          Criar sessão dynfilefs de "
"8000MB\n"
"    minios-session create raw 2000                Criar imagem de disco raw "
"de 2000MB\n"
"\n"
"  Operações de Sessão:\n"
"    minios-session resize 2 4000                  Redimensionar a sessão #2 "
"para 4000MB\n"
"    minios-session export 3 /tmp/backup.tar.zst   Exportar a sessão #3 para "
"um arquivo\n"
"    minios-session import /tmp/backup.tar.zst     Importar sessão de um "
"arquivo\n"
"    minios-session copy 2                         Copiar a sessão #2\n"
"    minios-session copy 2 --to-mode raw --size 3000  Copiar a sessão #2 como "
"raw com 3000MB\n"
"    minios-session convert 3 dynfilefs --size 2000   Converter a sessão #3 "
"para dynfilefs com 2000MB\n"
"\n"
"  Tratamento de Erros:\n"
"    minios-session create                         Pode falhar em FAT32/NTFS/"
"exFAT: \"Use o modo dynfilefs ou raw\"\n"
"    minios-session create raw 5000                Falhará em FAT32: limite "
"de tamanho de arquivo é 4096MB (4GB)\n"
"\n"
"  Saída JSON (para automação):\n"
"    minios-session --json list                    Listar sessões no formato "
"JSON\n"
"    minios-session active --json                  Obter informações da "
"sessão ativa como JSON\n"
"    minios-session info --json                    Obter informações do "
"sistema como JSON\n"
"\n"
"  Diretório de Sessões Personalizado:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create native\n"
"\n"
"        "

