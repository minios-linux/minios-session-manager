#: lib/minios_session.py:952
msgid ""
"MiniOS Session Manager - Command line tool for managing persistent sessions"
msgstr ""
"Gestor de Sessões MiniOS - Ferramenta de linha de comando para gerir sessões "
"persistentes"

#: lib/minios_session.py:954
msgid ""
"\n"
"GLOBAL OPTIONS:\n"
"  --json                    Output results in JSON format (can be used with "
"any command)\n"
"  --sessions-dir PATH       Use custom sessions directory instead of "
"default\n"
"\n"
"COMMANDS:\n"
"  list                      List all available sessions with detailed "
"information\n"
"  active                    Show currently active session (will boot next)\n"
"  running                   Show currently running session (current boot)\n"
"  info                      Show filesystem type and compatible session "
"modes\n"
"  activate SESSION_ID       Activate specified session (required: "
"session_id)\n"
"  create [OPTIONS]          Create new session (optional: --mode, --size)\n"
"  delete SESSION_ID         Delete specified session (required: session_id)\n"
"  cleanup [OPTIONS]         Delete old sessions (optional: --days, default: "
"30)\n"
"\n"
"SESSION MODES:\n"
"  native                    Direct filesystem changes (requires POSIX-"
"compatible filesystem)\n"
"  dynfilefs                 Dynamic file system overlay (works on any "
"filesystem, 4GB default)\n"
"  raw                       Raw disk image (works on any filesystem, custom "
"size required)\n"
"\n"
"COMMAND BEHAVIOR:\n"
"  • create without --mode: Uses native mode (may fail on FAT32/NTFS)\n"
"  • create without --size: Uses 4000MB (4GB) for dynfilefs/raw modes\n"
"  • cleanup without --days: Uses 30-day threshold for deletion\n"
"  • cleanup protects both active and running sessions from deletion\n"
"\n"
"EXAMPLES:\n"
"\n"
"  Basic Usage:\n"
"    minios-session list                           List all available "
"sessions\n"
"    minios-session active                         Show which session will "
"boot next\n"
"    minios-session running                        Show currently running "
"session\n"
"    minios-session info                           Show filesystem "
"compatibility info\n"
"\n"
"  Session Management:\n"
"    minios-session activate 2                     Set session #2 as default "
"for next boot\n"
"    minios-session delete 3                       Delete session #3 "
"permanently\n"
"    minios-session cleanup --days 30              Delete sessions older than "
"30 days\n"
"    minios-session cleanup                        Delete sessions older than "
"30 days (default)\n"
"\n"
"  Creating Sessions:\n"
"    minios-session create --mode native           Create native session "
"(filesystem changes)\n"
"    minios-session create --mode dynfilefs        Create 4GB dynfilefs "
"session\n"
"    minios-session create --mode dynfilefs --size 8000   Create 8GB "
"dynfilefs session\n"
"    minios-session create --mode raw --size 2000         Create 2GB raw disk "
"image\n"
"\n"
"  Error Handling:\n"
"    minios-session create                         May fail on FAT32: \"Use "
"dynfilefs or raw mode\"\n"
"    minios-session create --mode raw --size 5000 May fail on FAT32: "
"\"Exceeds 4000MB limit\"\n"
"\n"
"  JSON Output (for automation):\n"
"    minios-session --json list                    List sessions in JSON "
"format\n"
"    minios-session active --json                  Get active session info as "
"JSON\n"
"    minios-session info --json                    Get system info as JSON\n"
"\n"
"  Custom Session Directory:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create --mode native\n"
"\n"
"NOTE: Most write operations (activate, create, delete, cleanup) require root "
"privileges.\n"
"      The tool will automatically request privileges when needed.\n"
"        "
msgstr ""
"\n"
"OPÇÕES GLOBAIS:\n"
"  --json                    Saída de resultados em formato JSON (pode ser "
"usado com qualquer comando)\n"
"  --sessions-dir CAMINHO    Use um diretório de sessões personalizado em vez "
"de padrão\n"
"\n"
"COMANDOS:\n"
"  list                      Listar todas as sessões disponíveis com "
"informações detalhadas\n"
"  active                    Mostrar a sessão ativa no momento (será iniciada "
"a seguir)\n"
"  running                   Mostrar a sessão em execução no momento "
"(inicialização atual)\n"
"  info                      Mostrar o tipo de sistema de ficheiros e os "
"modos de sessão compatíveis\n"
"  activate ID_SESSÃO        Ativar a sessão especificada (obrigatório: "
"id_sessão)\n"
"  create [OPÇÕES]           Criar nova sessão (opcional: --mode, --size)\n"
"  delete ID_SESSÃO          Excluir a sessão especificada (obrigatório: "
"id_sessão)\n"
"  cleanup [OPÇÕES]         Excluir sessões antigas (opcional: --days, "
"padrão: 30)\n"
"\n"
"MODOS DE SESSÃO:\n"
"  native                    Alterações diretas no sistema de ficheiros "
"(requer sistema de ficheiros compatível com POSIX)\n"
"  dynfilefs                 Sobreposição de sistema de ficheiros dinâmico "
"(funciona em qualquer sistema de ficheiros, 4 GB padrão)\n"
"  raw                       Imagem de disco bruta (funciona em qualquer "
"sistema de ficheiros, tamanho personalizado obrigatório)\n"
"\n"
"COMPORTAMENTO DO COMANDO:\n"
"  • create sem --mode: usa o modo nativo (pode falhar em FAT32/NTFS)\n"
"  • create sem --size: usa 4000 MB (4 GB) para os modos dynfilefs/raw\n"
"  • cleanup sem --days: usa um limite de 30 dias para exclusão\n"
"  • cleanup protege as sessões ativas e em execução da exclusão\n"
"\n"
"EXEMPLOS:\n"
"\n"
"  Uso básico:\n"
"    minios-session list                           Listar todas as sessões "
"disponíveis\n"
"    minios-session active                         Mostrar qual sessão será "
"iniciada a seguir\n"
"    minios-session running                        Mostrar a sessão em "
"execução no momento\n"
"    minios-session info                           Mostrar informações de "
"compatibilidade do sistema de ficheiros\n"
"\n"
"  Gestão de sessão:\n"
"    minios-session activate 2                     Definir a sessão nº 2 como "
"padrão para a próxima inicialização\n"
"    minios-session delete 3                       Excluir a sessão nº 3 "
"permanentemente\n"
"    minios-session cleanup --days 30              Excluir sessões com mais "
"de 30 dias\n"
"    minios-session cleanup                        Excluir sessões com mais "
"de 30 dias (padrão)\n"
"\n"
"  Criando sessões:\n"
"    minios-session create --mode native           Criar sessão nativa "
"(alterações no sistema de ficheiros)\n"
"    minios-session create --mode dynfilefs        Criar sessão dynfilefs de "
"4 GB\n"
"    minios-session create --mode dynfilefs --size 8000   Criar sessão "
"dynfilefs de 8 GB\n"
"    minios-session create --mode raw --size 2000         Criar imagem de "
"disco bruta de 2 GB\n"
"\n"
"  Tratamento de erros:\n"
"    minios-session create                         Pode falhar em FAT32: "
"\"Use o modo dynfilefs ou raw\"\n"
"    minios-session create --mode raw --size 5000  Pode falhar em FAT32: "
"\"Excede o limite de 4000 MB\"\n"
"\n"
"  Saída JSON (para automação):\n"
"    minios-session --json list                    Listar sessões em formato "
"JSON\n"
"    minios-session active --json                  Obter informações da "
"sessão ativa como JSON\n"
"    minios-session info --json                    Obter informações do "
"sistema como JSON\n"
"\n"
"  Diretório de sessão personalizado:\n"
"    minios-session --sessions-dir /mnt/usb/sessions list\n"
"    minios-session --sessions-dir /tmp/test create --mode native\n"
"\n"
"NOTA: a maioria das operações de escrita (ativar, criar, excluir, limpar) "
"requerem privilégios de root.\n"
"      A ferramenta solicitará privilégios automaticamente quando "
"necessário.\n"
"        "

